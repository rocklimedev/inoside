{
  "compilerOptions": {
    // ────────────────────────────────────────────────────────────────
    // Language / Output
    // ────────────────────────────────────────────────────────────────
    "target": "ES2022", // ← upgraded (2025 safe)
    "module": "CommonJS", // or "NodeNext" if you want ESM
    "moduleResolution": "Node", // ← very important if you use NodeNext
    "experimentalDecorators": true, // ← required for @decorator syntax
    "emitDecoratorMetadata": true, // ← almost always needed with sequelize-typescript
    // ────────────────────────────────────────────────────────────────
    // Paths & Structure
    // ────────────────────────────────────────────────────────────────
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo", // speeds up incremental builds

    // ────────────────────────────────────────────────────────────────
    // Strictness & Safety (you already have strict — great!)
    // ────────────────────────────────────────────────────────────────
    "strict": true,
    "noImplicitAny": true, // already enabled by strict
    "noUncheckedIndexedAccess": true, // very useful with objects/arrays
    "exactOptionalPropertyTypes": true, // modern & safer optional props

    // ────────────────────────────────────────────────────────────────
    // Interop & Compatibility
    // ────────────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true, // helps with many ESM-only packages
    "skipLibCheck": true, // good tradeoff for speed
    "forceConsistentCasingInFileNames": true,

    // ────────────────────────────────────────────────────────────────
    // Emit / Declarations (optional but useful)
    // ────────────────────────────────────────────────────────────────
    // "declaration": true,                 // if you're publishing a library
    // "sourceMap": true,                   // very helpful for debugging
    "inlineSourceMap": false, // usually prefer separate .map files

    // ────────────────────────────────────────────────────────────────
    // Modern Node.js-friendly settings
    // ────────────────────────────────────────────────────────────────
    "lib": ["ES2023", "DOM"], // DOM if you ever do SSR / testing
    "types": ["node"] // makes sure global Node types are included
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
